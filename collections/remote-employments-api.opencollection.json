          "http": {
            "method": "GET",
            "url": "https://gateway.remote.com/v1/employments/:employment_id/administrative_details",
            "params": [
              {
                "name": "employment_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Show Administrative Details"
        },
        {
          "info": {
            "name": "Update Administrative Details",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://gateway.remote.com/v1/employments/:employment_id/administrative_details",
            "params": [
              {
                "name": "employment_id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update Administrative Details"
        }
      ]
    },
