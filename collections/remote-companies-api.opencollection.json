        {
          "info": {
            "name": "Delete A Company Manager",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://gateway.remote.com/v1/companies/:company_id/managers/:manager_id",
            "params": [
              {
                "name": "company_id",
                "value": "",
                "type": "path"
              },
              {
                "name": "manager_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete A Company Manager"
        }
      ]
    },
    {
      "info": {
        "name": "Departments",
        "type": "folder"
      },
      "items": [
        {
