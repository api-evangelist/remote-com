        },
        {
          "info": {
            "name": "Show A Company Manager",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://gateway.remote.com/v1/companies/:company_id/managers/:manager_id",
            "params": [
              {
                "name": "company_id",
                "value": "",
                "type": "path"
              },
              {
                "name": "manager_id",
                "value": "",
