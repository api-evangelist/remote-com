    },
    {
      "info": {
        "name": "SSO",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Show The Current SSO Configuration",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://gateway.remote.com/v1/sso_configuration"
          },
          "docs": "Show The Current SSO Configuration"
        },
        {
